<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>Game Client - Bảng điều khiển nhân vật | SignalR</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <style>
        * {
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', 'Poppins', system-ui, -apple-system, sans-serif;
            background: #0b0f1c;
            color: #eef2ff;
            margin: 0;
            padding: 24px;
            display: flex;
            flex-wrap: wrap;
            gap: 28px;
            justify-content: center;
        }

        /* panels */
        .panel {
            background: rgba(18, 22, 35, 0.95);
            backdrop-filter: blur(2px);
            border: 1px solid #2a2f42;
            border-radius: 28px;
            padding: 22px 24px;
            box-shadow: 0 20px 35px -12px rgba(0, 0, 0, 0.6);
            transition: all 0.2s;
        }

        .control-panel {
            flex: 1.2;
            min-width: 280px;
        }

        .log-panel {
            flex: 1.8;
            min-width: 340px;
            display: flex;
            flex-direction: column;
        }

        h3 {
            font-size: 1.35rem;
            font-weight: 600;
            margin-top: 0;
            margin-bottom: 1rem;
            letter-spacing: -0.2px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .control-panel h3 { color: #a5f0c0; border-left: 4px solid #4caf50; padding-left: 14px; }
        .log-panel h3:first-of-type { color: #ffb86b; border-left: 4px solid #ffb86b; padding-left: 14px; }
        .log-panel h3:last-of-type { color: #6bcbff; border-left: 4px solid #6bcbff; padding-left: 14px; margin-top: 20px; }

        input, button {
            border-radius: 60px;
            border: none;
            font-weight: 500;
            transition: 0.2s ease;
        }

        input {
            background: #1e243b;
            color: white;
            padding: 12px 18px;
            width: 100%;
            font-size: 0.9rem;
            border: 1px solid #333b54;
        }

        input:focus {
            outline: none;
            border-color: #4caf50;
            box-shadow: 0 0 0 2px rgba(76, 175, 80, 0.3);
        }

        button {
            background: #2c3e66;
            color: white;
            padding: 10px 18px;
            cursor: pointer;
            font-weight: 600;
            box-shadow: 0 2px 5px rgba(0,0,0,0.3);
        }

        button:hover {
            background: #3e5a85;
            transform: translateY(-1px);
        }

        button:active {
            transform: translateY(1px);
        }

        .btn-primary {
            background: #4caf50;
            width: 100%;
            font-size: 1rem;
            padding: 12px;
            margin-top: 8px;
        }

        .btn-primary:hover {
            background: #3d9c41;
        }

        .move-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
            margin: 18px 0 5px;
        }

        .move-grid button {
            background: #2c3e66;
            font-size: 1.4rem;
            padding: 12px 0;
            font-weight: bold;
            box-shadow: 0 4px 0 #121624;
        }

        .move-grid button:active {
            transform: translateY(2px);
            box-shadow: 0 1px 0 #121624;
        }

        #connectionStatus {
            background: #11161f;
            padding: 10px 16px;
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            font-weight: 500;
            margin-bottom: 12px;
        }

        .status-dot {
            height: 12px;
            width: 12px;
            border-radius: 50%;
            display: inline-block;
            transition: 0.1s;
        }

        .online { background-color: #4caf50; box-shadow: 0 0 6px #4caf50; }
        .offline { background-color: #f44336; }

        /* Danh sách nhân vật - dạng BUTTON siêu đẹp */
        #playerList {
            display: flex;
            flex-direction: column;
            gap: 14px;
            max-height: 340px;
            overflow-y: auto;
            padding-right: 6px;
        }

        /* style cho mỗi "nhân vật" dạng button */
        .character-card {
            background: #1a1f2e;
            border-radius: 60px;
            transition: all 0.2s;
            border: 1px solid #2f3a55;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 12px 8px 18px;
            backdrop-filter: blur(2px);
        }

        /* nút giao dịch riêng (nếu muốn) nhưng chính bản thân thẻ cũng là nút */
        .trade-btn {
            background: #ff8c42;
            border: none;
            border-radius: 40px;
            padding: 8px 18px;
            font-size: 0.75rem;
            font-weight: bold;
            color: #1f1a2e;
            margin-left: 12px;
            transition: 0.2s;
            box-shadow: 0 1px 4px rgba(0,0,0,0.4);
        }

        .trade-btn:hover {
            background: #ff9f5e;
            transform: scale(1.02);
        }

        .character-info {
            display: flex;
            align-items: center;
            gap: 14px;
            flex-wrap: wrap;
            flex: 1;
        }

        .character-avatar {
            background: #2c3e66;
            width: 44px;
            height: 44px;
            border-radius: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            font-weight: bold;
            color: #ffd966;
            box-shadow: inset 0 1px 2px #ffffff20, 0 2px 6px black;
        }

        .character-name {
            font-weight: 700;
            background: #0f1420;
            padding: 4px 12px;
            border-radius: 30px;
            font-size: 0.8rem;
            font-family: monospace;
            letter-spacing: 0.5px;
        }

        .character-position {
            font-size: 0.8rem;
            background: #232a3f;
            padding: 4px 12px;
            border-radius: 30px;
            color: #b9fbc0;
        }

        .self-badge {
            background: #2a5f4b;
            color: #c3ffdf;
            font-size: 0.7rem;
            padding: 4px 10px;
            border-radius: 30px;
            font-weight: bold;
        }

        /* riêng cho nhân vật của chính mình (không phải nút giao dịch) */
        .character-self {
            background: #1f2a3c;
            border: 1px solid #4caf5080;
            opacity: 0.9;
            cursor: default;
        }

        /* log */
        #log {
            background: #03060e;
            padding: 14px;
            border-radius: 20px;
            height: 260px;
            overflow-y: auto;
            font-family: 'Fira Code', 'Courier New', monospace;
            font-size: 12px;
            color: #b2f0b2;
            border: 1px solid #2a3348;
            box-shadow: inset 0 0 8px #00000040;
        }

        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: #191e2c;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb {
            background: #4caf50;
            border-radius: 10px;
        }

        hr {
            border-color: #2a2f42;
            margin: 16px 0;
        }

        .info-note {
            font-size: 0.7rem;
            color: #8f9bb3;
            margin-top: 14px;
            text-align: center;
        }
    </style>
</head>
<body>

<div class="panel control-panel">
    <h3>🎮 BẢNG ĐIỀU KHIỂN</h3>
    <div id="connectionStatus">
        <span class="status-dot offline" id="dot"></span>
        <span id="statusText">⚡ Chưa kết nối</span>
    </div>
    
    <hr>
    
    <label style="font-weight: 500;">🏷️ MÃ PHÒNG (MATCH ID)</label>
    <input type="text" id="matchId" value="DUNGEON_01" style="margin-top: 6px;">
    <button id="btnJoin" class="btn-primary" onclick="joinRoom()">🚪 VÀO PHÒNG / THAM GIA</button>
    
    <div style="margin-top: 28px;">
        <label>🧭 DI CHUYỂN NHÂN VẬT (X,Y,Z)</label>
        <div class="move-grid">
            <div></div>
            <button onclick="move(0, 1, 0)" title="Tăng Y">⬆️ Y</button>
            <div></div>
            <button onclick="move(-1, 0, 0)" title="Giảm X">⬅️ X</button>
            <button onclick="move(0, -1, 0)" title="Giảm Y">⬇️ Y</button>
            <button onclick="move(1, 0, 0)" title="Tăng X">➡️ X</button>
        </div>
        <div class="info-note">✨ Click các nút mũi tên để thay đổi vị trí → server đồng bộ tất cả người chơi</div>
    </div>
    <div class="info-note" style="margin-top: 12px;">
        🧙‍♂️ Mỗi nhân vật trong danh sách là một nút BẤM ĐƯỢC → Gửi yêu cầu giao dịch ngay!
    </div>
</div>

<div class="panel log-panel">
    <h3>🗡️ DANH SÁCH NHÂN VẬT (NHẤN VÀO ĐỂ GIAO DỊCH)</h3>
    <div id="playerList">
        <div style="text-align:center; padding:20px; color:#6c7a9e;">✨ Đang tải dữ liệu game...</div>
    </div>
    
    <h3>📡 NHẬT KÝ SỰ KIỆN</h3>
    <div id="log"></div>
</div>

<script>
    // ----------------------------- SIGNALR -----------------------------
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/gamehub")
        .withAutomaticReconnect([0, 2000, 5000, 10000])
        .build();

    // Trạng thái client
    let currentPlayerId = null;          // lưu connectionId của chính mình
    let currentMatchId = "DUNGEON_01";   // match mặc định
    let myPosition = { x: 0, y: 0, z: 0 };

    // DOM elements
    const matchIdInput = document.getElementById("matchId");
    const btnJoin = document.getElementById("btnJoin");
    const playerListDiv = document.getElementById("playerList");
    const logDiv = document.getElementById("log");

    // Helper: ghi log (mới nhất ở trên cùng)
    function writeLog(msg, type = "info") {
        const entry = document.createElement("div");
        const prefix = type === "error" ? "❌ " : (type === "trade" ? "💎 " : "📢 ");
        entry.innerText = `${prefix}${msg}`;
        entry.style.marginBottom = "6px";
        entry.style.borderBottom = "1px dotted #2a3348";
        entry.style.paddingBottom = "4px";
        logDiv.prepend(entry);
        if (logDiv.children.length > 80) logDiv.removeChild(logDiv.lastChild);
    }

    // Cập nhật giao diện kết nối
    function updateConnectionStatus(connected) {
        const dot = document.getElementById("dot");
        const statusText = document.getElementById("statusText");
        if (connected) {
            dot.className = "status-dot online";
            statusText.innerText = "🔗 Đã kết nối Server";
        } else {
            dot.className = "status-dot offline";
            statusText.innerText = "⚠️ Mất kết nối";
        }
    }

    // ================== GỬI YÊU CẦU GIAO DỊCH ==================
    async function requestTrade(targetPlayerId) {
        if (!targetPlayerId) return;
        if (targetPlayerId === currentPlayerId) {
            writeLog("🤝 Bạn không thể giao dịch với chính mình!", "error");
            return;
        }
        try {
            await connection.invoke("RequestTrade", targetPlayerId);
            writeLog(`✨ Đã gửi yêu cầu giao dịch đến nhân vật ${targetPlayerId.substring(0, 6)}...`, "trade");
        } catch (err) {
            writeLog(`Gửi giao dịch thất bại: ${err}`, "error");
        }
    }

    // Tham gia phòng
    async function joinRoom() {
        const room = matchIdInput.value.trim();
        if (!room) {
            writeLog("⚠️ Vui lòng nhập mã phòng (Match ID)", "error");
            return;
        }
        currentMatchId = room;
        try {
            await connection.invoke("JoinMatch", room);
            writeLog(`🏠 Đã tham gia / tạo phòng: "${room}"`, "info");
            btnJoin.disabled = true;
            matchIdInput.disabled = true;
            btnJoin.style.opacity = "0.6";
            btnJoin.innerText = "✓ ĐÃ TRONG PHÒNG";
        } catch (err) {
            writeLog(`Không thể vào phòng: ${err}`, "error");
        }
    }

    // Di chuyển nhân vật & gửi tọa độ
    async function move(dx, dy, dz) {
        if (!currentMatchId) {
            writeLog("❌ Bạn chưa tham gia phòng nào! Hãy bấm 'VÀO PHÒNG' trước.", "error");
            return;
        }
        myPosition.x += dx;
        myPosition.y += dy;
        myPosition.z += dz;
        try {
            await connection.invoke("SendPosition", currentMatchId, myPosition.x, myPosition.y, myPosition.z);
            writeLog(`🚶‍♂️ Di chuyển → (${myPosition.x}, ${myPosition.y}, ${myPosition.z})`, "info");
        } catch (err) {
            writeLog(`Lỗi gửi vị trí: ${err}`, "error");
        }
    }

    // ================== HIỂN THỊ DANH SÁCH NHÂN VẬT DẠNG BUTTON ==================
    // Mỗi người chơi (ngoại trừ chính mình) sẽ hiển thị như một nút bấm có thể tương tác "Giao dịch"
    // Yêu cầu: "thay vì chỉ in chữ hãy hiện button như nhân vật" -> mỗi nhân vật là một thẻ có thể click
    // Cách làm: Mỗi nhân vật khác sẽ có container dạng .character-card và toàn bộ card có thể click để gửi giao dịch,
    // kèm nút trade nổi bật. Riêng nhân vật của bạn hiển thị dạng đặc biệt (không thể click giao dịch).
    function renderPlayerList(playersArray) {
        if (!playersArray || playersArray.length === 0) {
            playerListDiv.innerHTML = `<div style="text-align:center; padding:20px; color:#6c7a9e;">🌟 Chưa có người chơi trong phòng</div>`;
            return;
        }

        // Xóa nội dung cũ và render lại toàn bộ
        playerListDiv.innerHTML = "";

        playersArray.forEach(player => {
            const playerId = player.id;
            const posX = player.positionX ?? 0;
            const posY = player.positionY ?? 0;
            const posZ = player.positionZ ?? 0;
            const shortId = playerId.length > 8 ? playerId.substring(0, 8) + ".." : playerId;
            
            // Tạo container chính (card)
            const card = document.createElement("div");
            card.className = "character-card";
            
            // Avatar giả lập dựa trên ký tự đầu
            const avatarChar = (shortId.charCodeAt(0) % 26 + 65).toString(36).toUpperCase();
            
            // Phần thông tin nhân vật
            const infoDiv = document.createElement("div");
            infoDiv.className = "character-info";
            
            // Avatar icon
            const avatarSpan = document.createElement("div");
            avatarSpan.className = "character-avatar";
            avatarSpan.innerText = avatarChar;
            
            // Tên / ID rút gọn
            const nameSpan = document.createElement("span");
            nameSpan.className = "character-name";
            nameSpan.innerText = shortId;
            
            // Vị trí
            const posSpan = document.createElement("span");
            posSpan.className = "character-position";
            posSpan.innerText = `📍 (${posX}, ${posY}, ${posZ})`;
            
            infoDiv.appendChild(avatarSpan);
            infoDiv.appendChild(nameSpan);
            infoDiv.appendChild(posSpan);
            
            // Kiểm tra nếu đây là chính người chơi hiện tại
            const isSelf = (currentPlayerId && playerId === currentPlayerId);
            
            if (isSelf) {
                // Nhân vật của chính mình -> KHÔNG phải nút giao dịch, chỉ hiển thị đặc biệt
                card.classList.add("character-self");
                const selfBadge = document.createElement("span");
                selfBadge.className = "self-badge";
                selfBadge.innerText = "✨ BẠN ✨";
                infoDiv.appendChild(selfBadge);
                card.appendChild(infoDiv);
                // Không có nút trade, không có sự kiện click giao dịch (chỉ hiển thị)
                playerListDiv.appendChild(card);
            } else {
                // *** NHÂN VẬT KHÁCH: HIỆN THỊ NHƯ BUTTON CÓ THỂ CLICK ***
                // Tạo nút giao dịch riêng biệt
                const tradeButton = document.createElement("button");
                tradeButton.className = "trade-btn";
                tradeButton.innerText = "🤝 GIAO DỊCH";
                tradeButton.title = `Gửi yêu cầu tới ${shortId}`;
                
                // Thêm sự kiện click cho nút trade (ngăn chặn sự kiện nổi bọt lên card)
                tradeButton.addEventListener("click", (e) => {
                    e.stopPropagation();
                    requestTrade(playerId);
                });
                
                // Toàn bộ card cũng có thể click để giao dịch (tiện lợi)
                card.style.cursor = "pointer";
                card.addEventListener("click", (e) => {
                    // Không bị ảnh hưởng nếu click vào nút trade (đã stopPropagation)
                    requestTrade(playerId);
                });
                card.appendChild(infoDiv);
                card.appendChild(tradeButton);
                playerListDiv.appendChild(card);
            }
        });
        
        // Nếu có quá nhiều nhân vật, thêm hint
        if (playersArray.length > 0) {
            const hint = document.createElement("div");
            hint.style.fontSize = "0.7rem";
            hint.style.textAlign = "center";
            hint.style.marginTop = "12px";
            hint.style.color = "#a5b4d9";
            hint.innerText = "💡 Nhấn vào nhân vật hoặc nút GIAO DỊCH để gửi yêu cầu";
            playerListDiv.appendChild(hint);
        }
    }

    // ================== LẮNG NGHE SỰ KIỆN TỪ SERVER ==================
    
    // 1. Nhận trạng thái game loop (danh sách người chơi và vị trí)
    connection.on("UpdateGameState", (players) => {
        // Cập nhật vị trí của chính mình trong mảng nếu tìm thấy (để đồng bộ local)
        if (players && currentPlayerId) {
            const me = players.find(p => p.id === currentPlayerId);
            if (me) {
                myPosition = { x: me.positionX ?? 0, y: me.positionY ?? 0, z: me.positionZ ?? 0 };
            }
        }
        // Render danh sách NHÂN VẬT dạng button tương tác
        renderPlayerList(players);
    });

    // 2. Có người chơi mới tham gia
    connection.on("PlayerJoined", (playerId) => {
        writeLog(`✨ Nhân vật mới gia nhập thế giới: ${playerId.substring(0, 8)}...`, "info");
    });

    // 3. Nhận yêu cầu giao dịch từ người chơi khác
    connection.on("RequestTrade", (fromPlayerId) => {
        writeLog(`💬 [GIAO DỊCH] Nhân vật ${fromPlayerId.substring(0, 6)}... muốn giao dịch với bạn!`, "trade");
        // Tạo hiệu ứng cảnh báo nhẹ (có thể thêm popup tương lai)
        const logBox = document.getElementById("log");
        if (logBox) {
            const tradeNotify = document.createElement("div");
            tradeNotify.style.background = "#ff980030";
            tradeNotify.style.padding = "4px 8px";
            tradeNotify.style.borderRadius = "30px";
            tradeNotify.style.margin = "6px 0";
            tradeNotify.innerText = `🤝 Yêu cầu giao dịch từ ${fromPlayerId.substring(0, 8)}! Hãy liên hệ qua hệ thống.`;
            logDiv.prepend(tradeNotify);
        }
    });
    
    // 4. Tuỳ chọn: sự kiện rời phòng (nếu server có broadcast)
    connection.on("PlayerLeft", (playerId) => {
        writeLog(`🚪 Nhân vật rời khỏi thế giới: ${playerId.substring(0, 8)}...`, "info");
    });
    
    // 5. Kết nối lại / mất kết nối
    connection.onreconnecting((error) => {
        updateConnectionStatus(false);
        writeLog("🔄 Mất kết nối, đang thử kết nối lại...", "error");
    });
    
    connection.onreconnected((connectionId) => {
        updateConnectionStatus(true);
        currentPlayerId = connectionId;
        writeLog(`✅ Kết nối khôi phục! ID mới: ${connectionId.substring(0, 8)}...`, "info");
        // Nếu đã từng join phòng trước đó, gửi lại tọa độ hoặc cập nhật phòng? 
        // Server vẫn nhớ group? thường signalR tự động tham gia lại group nếu dùng WithAutomaticReconnect và server có xử lý OnReconnected.
        // Để an toàn, ta có thể gửi lại vị trí hiện tại sau khi reconnect nếu đã có matchId
        if (currentMatchId && btnJoin.disabled === true) {
            setTimeout(async () => {
                try {
                    await connection.invoke("SendPosition", currentMatchId, myPosition.x, myPosition.y, myPosition.z);
                    writeLog(`📡 Đã đồng bộ lại vị trí sau khi reconnect`, "info");
                } catch(e) { /* bỏ qua */ }
            }, 500);
        }
    });
    
    connection.onclose((error) => {
        updateConnectionStatus(false);
        writeLog("🔌 Kết nối đã đóng. Trang sẽ tự động thử kết nối lại.", "error");
        btnJoin.disabled = false;
        matchIdInput.disabled = false;
        btnJoin.style.opacity = "1";
        btnJoin.innerText = "🚪 VÀO PHÒNG";
    });

    // ================== KHỞI TẠO KẾT NỐI SIGNALR ==================
    async function startConnection() {
        try {
            await connection.start();
            currentPlayerId = connection.connectionId;
            updateConnectionStatus(true);
            writeLog(`✅ Kết nng, người dùng chủ động bấm nút
            // Nhưng nếu muốn trải nghiệm nhanh, cóối SignalR thành công! ID nhân vật: ${currentPlayerId.substring(0, 10)}...`, "info");
            // Sau khi kết nối, không tự động join phò thể hiển thị sẵn sàng
        } catch (err) {
            console.error(err);
            updateConnectionStatus(false);
            writeLog(`❌ Không thể kết nối server: ${err}`, "error");
            setTimeout(startConnection, 5000);
        }
    }
    
    // Hàm hỗ trợ gán lại sự kiện cho các nút move khi cần (đã có sẵn global)
    window.joinRoom = joinRoom;
    window.move = move;
    window.requestTrade = requestTrade;   // để dùng nếu cần từ console
    
    // Khởi động kết nối
    startConnection();
    
    // Bổ sung: nếu người dùng thay đổi matchId trước khi join thì vẫn ổn
    // Hỗ trợ reset giao diện nếu cần thoát phòng ảo (không cần thiết)
    // Thêm thông báo hướng dẫn
    writeLog("🎮 CHÀO MỪNG! Hãy nhấn 'VÀO PHÒNG' và di chuyển. Mỗi nhân vật trong danh sách là một nút để giao dịch.", "info");
    
    // Chú thích: Hiện tại mỗi người chơi khác hiển thị dạng card có thể click (toàn bộ card) + nút giao dịch riêng.
    // Đáp ứng yêu cầu: "thay vì chỉ in chữ hãy hiện button như nhân vật" – tất cả nhân vật khác đều là button tương tác rõ ràng.
</script>
