<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Game Client - Giao dịch vàng & trang bị</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Segoe UI', sans-serif; background: #0b0f1c; color: #eef2ff; margin: 0; padding: 20px; display: flex; gap: 20px; }
        .panel { background: #121625; border-radius: 24px; padding: 20px; border: 1px solid #2a2f42; }
        .control-panel { flex: 1; min-width: 300px; }
        .log-panel { flex: 2; }
        button { background: #2c3e66; border: none; padding: 8px 16px; border-radius: 40px; color: white; cursor: pointer; transition: 0.2s; }
        button:hover { filter: brightness(1.2); }
        button:disabled { background: #4b5563; cursor: not-allowed; }
        .trade-btn { background: #ff8c42; }
        .accept-btn { background: #4caf50; }
        .decline-btn { background: #f44336; }
        .character-card { background: #1a1f2e; border-radius: 60px; display: flex; justify-content: space-between; align-items: center; padding: 8px 16px; margin-bottom: 10px; border: 1px solid #2a2f42;}
        .trade-notification { background: #1e2a2f; border-left: 5px solid #ffaa44; border-radius: 12px; padding: 16px; margin-top: 16px; display: flex; flex-direction: column; gap: 12px; }
        .trade-actions { display: flex; gap: 10px; }
        #log { background: #03060e; height: 350px; overflow-y: auto; font-family: monospace; padding: 10px; border-radius: 16px; border: 1px solid #1a1f2e;}
        .log-entry { margin-bottom: 4px; border-bottom: 1px solid #1a1f2e; padding-bottom: 4px;}
        .move-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; width: 150px; margin-top: 12px; }
        .trade-input-group { background: #0f1320; padding: 16px; border-radius: 16px; margin-top: 16px; border: 1px solid #2a2f42;}
        .trade-input-group label { font-size: 0.8rem; display: block; margin-top: 8px; color: #bbd9ff; }
        input, select { background: #1e243b; color: white; padding: 10px; border-radius: 8px; border: 1px solid #2a2f42; width: 100%; margin-top: 4px;}
        hr { border-color: #2a2f42; margin: 16px 0; }
    </style>
</head>
<body>

<div class="panel control-panel">
    <h3>🎮 GIAO DỊCH & ĐIỀU KHIỂN</h3>
    <div id="connectionStatus">🔴 Đang kết nối...</div>
    <hr>
    
    <label>🏷️ MÃ PHÒNG</label>
    <input type="text" id="matchId" value="MAP_1">
    <button id="btnJoin" onclick="joinRoom()" style="margin-top: 10px; width: 100%;">🚪 VÀO PHÒNG</button>

    <div style="margin-top: 20px;">
        <label>🧭 DI CHUYỂN</label>
        <div class="move-grid">
            <div></div><button onclick="move(0,1,0)">↑</button><div></div>
            <button onclick="move(-1,0,0)">←</button><button onclick="move(0,-1,0)">↓</button><button onclick="move(1,0,0)">→</button>
        </div>
    </div>

    <div class="trade-input-group">
        <div style="font-weight: bold; margin-bottom: 10px;">💰 CHUẨN BỊ GIAO DỊCH</div>
        <label>🪙 Số Vàng</label>
        <input type="number" id="tradeGold" value="100" min="0">
        <label>⚔️ Vật phẩm</label>
        <select id="itemType">
            <option value="Sword">🗡️ Kiếm</option>
            <option value="Shield">🛡️ Khiên</option>
            <option value="Potion">🧪 Bình máu</option>
        </select>
        <label>📦 Số lượng</label>
        <input type="number" id="itemQuantity" value="1" min="1">
    </div>

    <div id="tradeRequestContainer"></div>
</div>

<div class="panel log-panel">
    <h3>👥 DANH SÁCH NHÂN VẬT (<span id="myPlayerIdText"></span>)</h3>
    <div id="playerList">Đang chờ vào phòng...</div>
    <hr>
    <h3>📜 NHẬT KÝ</h3>
    <div id="log"></div>
</div>

<script>
    // 1. KHỞI TẠO DỮ LIỆU
    const playerId = crypto.randomUUID(); 
    document.getElementById("myPlayerIdText").innerText = "Bạn: " + playerId.substring(0,8);
    
    let currentMatchId = "";
    let myPos = { x: 0, y: 0, z: 0 };
    let currentPendingTrade = null; // Lưu object giao dịch đang chờ xử lý

    // 2. CẤU HÌNH SIGNALR
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("http://localhost:5033/gamehub") // SỬA URL NÀY THEO BACKEND CỦA BẠN (VD: https://localhost:7000/gamehub)
        .withAutomaticReconnect()
        .build();

    // 3. HÀM TIỆN ÍCH
    function writeLog(msg, type = "info") {
        const logDiv = document.getElementById("log");
        const prefix = type === "error" ? "❌ " : (type === "trade" ? "💎 " : "📢 ");
        const entry = document.createElement("div");
        entry.className = "log-entry";
        
        // Lấy thời gian hiện tại
        const timeString = new Date().toLocaleTimeString('vi-VN');
        entry.innerHTML = `<span style="color:#8f9bb3; font-size:0.8rem">[${timeString}]</span> ${prefix}${msg}`;
        
        logDiv.prepend(entry);
    }

    // 4. CHỨC NĂNG GAME
    async function joinRoom() {
        const matchId = document.getElementById("matchId").value;
        if (!matchId) return;
        currentMatchId = matchId;
        
        try {
            await connection.invoke("JoinMatch", matchId, playerId);
            writeLog(`🏠 Đã vào phòng ${matchId}`, "info");
            document.getElementById("btnJoin").disabled = true;
            document.getElementById("btnJoin").innerText = "ĐANG Ở TRONG PHÒNG";
        } catch (err) {
            writeLog(`Lỗi vào phòng: ${err.message || err}`, "error");
        }
    }

    async function move(dx, dy, dz) {
        if (!currentMatchId) { 
            writeLog("Bạn chưa vào phòng!", "error"); 
            return; 
        }
        myPos.x += dx; myPos.y += dy; myPos.z += dz;
        try {
            await connection.invoke("SendPosition", currentMatchId, myPos.x, myPos.y, myPos.z);
            writeLog(`🚶 Di chuyển đến toạ độ: (${myPos.x}, ${myPos.y}, ${myPos.z})`);
        } catch (err) { 
            writeLog(`Lỗi di chuyển: ${err}`, "error"); 
            // Undo vị trí nếu lỗi
            myPos.x -= dx; myPos.y -= dy; myPos.z -= dz;
        }
    }

    // 5. CHỨC NĂNG GIAO DỊCH
    async function requestTrade(targetPlayerId) {
        if (targetPlayerId === playerId) {
            writeLog("Không thể tự giao dịch với bản thân!", "error");
            return;
        }

        const gold = parseInt(document.getElementById("tradeGold").value) || 0;
        const quantity = parseInt(document.getElementById("itemQuantity").value) || 0;
        const itemType = document.getElementById("itemType").options[document.getElementById("itemType").selectedIndex].text;

        if (gold <= 0 && quantity <= 0) {
            writeLog("Vui lòng nhập số vàng hoặc vật phẩm hợp lệ (>0)", "error");
            return;
        }

        try {
            // LƯU Ý: Thứ tự tham số phải khớp với C# GameHub: RequestTrade(string targetPlayerId, decimal goldAmount, int quantity)
            await connection.invoke("RequestTrade", targetPlayerId, gold, quantity);
            writeLog(`📨 Đã gửi yêu cầu giao dịch: ${quantity} x ${itemType} & ${gold} vàng đến người chơi ${targetPlayerId.substring(0,8)}`, "trade");
        } catch (err) {
            writeLog(`Lỗi gửi giao dịch: ${err.message || err}`, "error");
        }
    }

    // Hàm gọi khi bấm nút Đồng ý / Từ chối giao dịch người khác gửi
    async function respondToTrade(isAccept) {
    if (!currentPendingTrade) return;

    // Lấy ID giao dịch và ID người gửi từ object đã lưu
    const tId = currentPendingTrade.id || currentPendingTrade.Id;
    const senderId = currentPendingTrade.fromPlayerId || currentPendingTrade.FromPlayerId;

    try {
        // Gọi lên Hub: ResponseTrade(string tradeId, string targetPlayerId, bool isAccept)
        // Lưu ý: targetPlayerId ở đây chính là người đã gửi yêu cầu cho bạn ban đầu
        await connection.invoke("ResponseTrade", tId, senderId, isAccept);
        
        writeLog(`✅ Bạn đã ${isAccept ? "CHẤP NHẬN" : "TỪ CHỐI"} giao dịch`, "trade");
        clearTradeNotification();
    } catch (err) {
        writeLog(`Lỗi phản hồi: ${err.message}`, "error");
    }
}

    // Hiển thị UI khi có người gửi giao dịch đến
    function showTradeOffer(trade) {
    if (!trade) return;
    
    // Gán vào biến toàn cục để dùng khi bấm nút Respond
    currentPendingTrade = trade; 
    
    // Xử lý trường hợp C# trả về PascalCase (FromPlayerId) hoặc camelCase (fromPlayerId)
    const senderId = trade.fromPlayerId || trade.FromPlayerId || "Người chơi ẩn danh";
    const gold = trade.goldAmount ?? trade.GoldAmount ?? 0;
    const qty = trade.quantity ?? trade.Quantity ?? 0;
    const tId = trade.id || trade.Id;

    console.log("Đang hiển thị giao dịch từ:", senderId);

    const container = document.getElementById("tradeRequestContainer");
    
    // Tạo nội dung HTML với ID chuẩn để gắn sự kiện
    container.innerHTML = `
        <div class="trade-notification" style="border: 2px solid #ff8c42; animation: pulse 2s infinite;">
            <div style="margin-bottom: 10px;">
                🤝 <strong>Người chơi ${senderId.substring(0, 8)}</strong> muốn giao dịch:
            </div>
            <div style="color: #ffaa44; font-weight: bold; font-size: 1.1rem; margin-bottom: 15px;">
                🪙 ${gold} Vàng &nbsp;|&nbsp; 📦 ${qty} Vật phẩm
            </div>
            <div class="trade-actions" style="display: flex; gap: 10px;">
                <button class="accept-btn" id="btnAcceptTrade" style="flex: 1; padding: 12px;">✅ ĐỒNG Ý</button>
                <button class="decline-btn" id="btnDeclineTrade" style="flex: 1; padding: 12px;">❌ TỪ CHỐI</button>
            </div>
        </div>
    `;

    // Gắn sự kiện trực tiếp sau khi render để tránh lỗi
    document.getElementById("btnAcceptTrade").onclick = () => respondToTrade(true);
    document.getElementById("btnDeclineTrade").onclick = () => respondToTrade(false);
}

    function clearTradeNotification() {
        currentPendingTrade = null;
        document.getElementById("tradeRequestContainer").innerHTML = "";
    }

    // 6. RENDER GIAO DIỆN NGƯỜI CHƠI
    function renderPlayers(players) {
        const container = document.getElementById("playerList");
        if (!players || players.length === 0) {
            container.innerHTML = "<div style='color: #8f9bb3'>✨ Chưa có người chơi nào trong phòng</div>";
            return;
        }
        
        container.innerHTML = "";
        players.forEach(p => {
            const isSelf = (p.id === playerId);
            const card = document.createElement("div");
            card.className = "character-card";
            
            // Xử lý tọa độ (Phòng trường hợp backend trả về null/undefined)
            const px = p.positionX || 0;
            const py = p.positionY || 0;
            const pz = p.positionZ || 0;

            card.innerHTML = `
                <div>
                    <strong style="color: ${isSelf ? '#4caf50' : '#bbd9ff'}">${p.id.substring(0,8)}</strong> 
                    <span style="font-size: 0.8rem; color: #8f9bb3">📍(${px}, ${py}, ${pz})</span>
                </div>
                ${!isSelf ? `<button class="trade-btn" onclick="requestTrade('${p.id}')">🤝 Giao dịch</button>` : '<span style="color:#4caf50; font-size:0.9rem">✨ Bạn</span>'}
            `;
            container.appendChild(card);
        });
    }

    // ==========================================
    // 7. LẮNG NGHE SỰ KIỆN SIGNALR TỪ BACKEND
    // ==========================================
    
    connection.on("MatchStateSync", (players) => renderPlayers(players));
    
    connection.on("UpdatePlayerPositions", (players) => renderPlayers(players));
    
    connection.on("PlayerJoined", (playerIdJoined) => {
        if(playerIdJoined !== playerId) {
            writeLog(`✨ Người chơi ${playerIdJoined.substring(0,8)} vừa vào phòng`);
        }
    });

    // Bắt lỗi Giao dịch do Backend tự ném ra (Exception)
    connection.on("TradeError", (errorMessage) => {
        writeLog(`⚠️ Lỗi giao dịch: ${errorMessage}`, "error");
    });

    // Lắng nghe sự kiện người khác gửi giao dịch cho mình
    // *Lưu ý: Phụ thuộc vào Backend gửi object hay các biến rời. 
    // Giả sử NotificationService của C# gửi nguyên object Trade
    connection.on("ReceiveTradeOffer", (trade) => {
        writeLog(`📩 Nhận yêu cầu giao dịch từ ${trade.fromPlayerId.substring(0,8)}`, "trade");
        showTradeOffer(trade);
    });

    // Kết quả sau khi đối phương bấm Accept / Reject
    connection.on("TradeResult", (message) => {
        writeLog(`📢 Thông báo giao dịch: ${message}`, "trade");
        clearTradeNotification();
    });

    // ==========================================
    // 8. KHỞI ĐỘNG KẾT NỐI
    // ==========================================
    async function startSignalR() {
        try {
            await connection.start();
            document.getElementById("connectionStatus").innerHTML = "🟢 Đã kết nối máy chủ";
            document.getElementById("connectionStatus").style.color = "#4caf50";
            writeLog("✅ Kết nối SignalR thành công.");
        } catch (err) {
            document.getElementById("connectionStatus").innerHTML = "🔴 Lỗi kết nối, đang thử lại...";
            document.getElementById("connectionStatus").style.color = "#f44336";
            setTimeout(startSignalR, 5000); // Thử kết nối lại sau 5 giây
        }
    }
    

    startSignalR();

</script>
</body>
</html>